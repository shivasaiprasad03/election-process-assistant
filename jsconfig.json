{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "checkJs": true,
    "strictNullChecks": false
  },
  "include": ["src/**/*.js", "server/**/*.js", "tests/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
